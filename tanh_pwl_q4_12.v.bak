odule tanh_pwl_q4_12 (
    x,
    y
);
	input  signed [15:0] x;
	output reg signed [15:0] y;
    always @(*) begin
        if (x >= 16'sd6144) begin
            // Saturado Positivo: y = 1.0
            y = 16'sd4096; 
            
        end else if (x >= 16'sd2048) begin
            // Reta superior: y = 0.5x + 0.25
            y = (x >>> 1) + 16'sd1024; 
            
        end else if (x > -16'sd2048) begin
            // Região linear central: y = x
            y = x; 
            
        end else if (x > -16'sd6144) begin
            // Reta inferior: y = 0.5x - 0.25
            y = (x >>> 1) - 16'sd1024; 
            
        end else begin
            // Saturado Negativo: y = -1.0
            y = -16'sd4096; 
        end
    end

endmodule